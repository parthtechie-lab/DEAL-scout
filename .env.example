# Copy this file to .env for local testing (never commit the real .env)
# For GitHub Actions, add these same values as repo Secrets instead
# (Settings -> Secrets and variables -> Actions -> New repository secret)

# Get from @BotFather on Telegram (this is your ALERT bot, separate from the reader below)
TELEGRAM_BOT_TOKEN=

# Your own Telegram user/chat id, so the bot knows where to send alerts
# (message @userinfobot on Telegram to get your numeric id)
TELEGRAM_CHAT_ID=

# Get from https://my.telegram.org -> API Development Tools
# This lets the script READ channels (Telethon acts as a logged-in user, not a bot)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Generated once locally by running scripts/generate_session.py
# Then stored as a GitHub Secret (TELEGRAM_SESSION) so Actions doesn't need to log in every run
TELEGRAM_SESSION=
