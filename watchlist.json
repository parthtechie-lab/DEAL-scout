  "extraction_patterns": {
    "price_regex":           ["₹\\s?([0-9,]+)(?:/-)?", "Rs\\.?\\s?([0-9,]+)", "INR\\s?([0-9,]+)"],
    "discount_percent_regex":["([0-9]{1,3})\\s?%\\s?(?:off|discount)"],
    "coupon_code_regex":     ["(?:use|apply|code|coupon|promo)[:\\s]+([A-Z][A-Z0-9]{3,14})","\"([A-Z][A-Z0-9]{4,14})\""],
    "expiry_regex":          ["valid till\\s*([0-9]{1,2}[a-zA-Z\\s0-9]{0,15})","expires?\\s*(?:on)?\\s*([0-9]{1,2}[a-zA-Z\\s0-9]{0,15})"]
  },

  "matching_rules": {
    "min_reliability_score": 5,
    "fuzzy_threshold": 85,
    "dedup_window_hours": 6,
    "min_priority_score_to_alert": 40,
    "priority_weights": {
      "discount_percent":    0.35,
      "source_reliability":  0.25,
      "keyword_match_count": 0.20,
      "price_below_target":  0.20
    }
  },

  "quiet_hours": {
    "start": "22:00",
    "end":   "08:00",
    "timezone": "Asia/Kolkata"
  }
}
